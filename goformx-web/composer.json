{
    "name": "goformx/web",
    "description": "GoFormX web application — built on Waaseyaa",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.4",
        "waaseyaa/foundation": "0.1.x-dev",
        "waaseyaa/user": "0.1.x-dev",
        "waaseyaa/routing": "0.1.x-dev",
        "waaseyaa/entity": "0.1.x-dev",
        "waaseyaa/access": "0.1.x-dev",
        "waaseyaa/config": "0.1.x-dev",
        "waaseyaa/ssr": "0.1.x-dev",
        "waaseyaa/cache": "0.1.x-dev",
        "waaseyaa/plugin": "0.1.x-dev",
        "waaseyaa/typed-data": "0.1.x-dev",
        "waaseyaa/validation": "0.1.x-dev",
        "waaseyaa/field": "0.1.x-dev",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "suggest": {
        "waaseyaa/auth": "Authentication — not yet published (0.1.x-dev)",
        "waaseyaa/billing": "Stripe billing — not yet published (0.1.x-dev)",
        "waaseyaa/inertia": "Inertia v3 SSR — not yet published (0.1.x-dev)",
        "waaseyaa/entity-storage": "Entity storage — not yet published (0.1.x-dev)",
        "waaseyaa/mail": "Mail system — not yet published (0.1.x-dev)",
        "waaseyaa/database-legacy": "Database legacy — not yet published (0.1.x-dev)"
    },
    "autoload": {
        "psr-4": {
            "GoFormX\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GoFormX\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
